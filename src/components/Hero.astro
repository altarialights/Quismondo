---
const quickLinks = [
  { label: "Nuestro Patrimonio", icon: "heritage" },
  { label: "Agenda Municipal", icon: "calendar" },
  { label: "Participa en tu Pueblo", icon: "heart" },
];
---

<section class="relative isolate overflow-hidden bg-[#F8F5EF]">
  <div class="absolute inset-0 z-0 lg:inset-y-0 lg:left-[38%] lg:right-0">
    <img
      src="/hero.png"
      alt="Quismondo, tierra de Tinani"
      class="h-full w-full object-cover object-[72%_center] md:object-[78%_center] lg:object-[48%_center]"
      width="1086"
      height="1448"
    />
  </div>

  <div class="absolute inset-y-0 left-0 z-[1] w-[76%] bg-[linear-gradient(90deg,#F8F5EF_0%,rgba(248,245,239,0.98)_46%,rgba(248,245,239,0.6)_76%,rgba(248,245,239,0)_100%)] md:w-[62%] lg:hidden"></div>
  <div class="absolute inset-x-0 top-0 z-[1] h-[46%] bg-[linear-gradient(180deg,rgba(248,245,239,0.96)_0%,rgba(248,245,239,0.78)_44%,rgba(248,245,239,0)_100%)] lg:hidden"></div>
  <div class="absolute inset-x-0 bottom-0 z-[1] h-[30%] bg-[linear-gradient(0deg,#F8F5EF_0%,rgba(248,245,239,0.72)_38%,rgba(248,245,239,0)_100%)] lg:h-[18%]"></div>
  <div class="absolute inset-y-0 left-[35%] z-[1] hidden w-[390px] bg-gradient-to-r from-[#F8F5EF] via-[#F8F5EF]/82 to-transparent lg:block xl:left-[37%]"></div>

  <div class="relative z-10 mx-auto flex min-h-[760px] w-full max-w-[1600px] flex-col px-5 pb-0 pt-16 sm:px-8 sm:pt-18 lg:min-h-[calc(100vh-112px)] lg:justify-center lg:px-10 lg:py-12 xl:px-16">
    <div class="max-w-[420px] lg:max-w-[560px]">
      <p class="text-[17px] font-semibold uppercase tracking-normal text-[#B9863B] lg:text-[20px]">
        Bienvenidos a
      </p>
      <h1 class="mt-2 max-w-full font-serif text-[clamp(3.35rem,15vw,5rem)] font-medium leading-none tracking-normal text-[#071D3A] md:text-[clamp(3.7rem,10vw,4.8rem)] lg:mt-3 lg:text-[clamp(5.4rem,7.4vw,8.8rem)]">
        Quismondo
      </h1>

      <div class="mt-6 flex w-full max-w-[320px] items-center gap-5 text-[#B9863B] lg:mt-8 lg:max-w-[350px]">
        <span class="h-px flex-1 bg-[#B9863B]/75"></span>
        <img
          src="/escudo.png"
          alt=""
          class="h-7 w-auto shrink-0 object-contain"
          width="330"
          height="585"
          aria-hidden="true"
        />
        <span class="h-px flex-1 bg-[#B9863B]/75"></span>
      </div>

      <p class="mt-6 max-w-[360px] text-[18px] font-medium leading-[1.45] text-[#102947] lg:mt-8 lg:max-w-[430px] lg:text-[22px]">
        Tradición que nos une, historia que nos enorgullece, pueblo que late.
        <strong class="mt-1 block font-extrabold">Tierra de Tinani.</strong>
      </p>

    </div>

    <div class="mt-auto flex w-full max-w-[370px] flex-col gap-4 lg:mt-9 lg:max-w-[510px] lg:flex-row">
        <a
          href="#"
          class="inline-flex h-16 w-full items-center justify-center gap-3 rounded-[8px] bg-[#071D3A] px-5 text-[16px] font-semibold text-white shadow-[0_18px_34px_rgba(7,29,58,0.22)] outline-none transition hover:bg-[#0b2c57] focus-visible:ring-2 focus-visible:ring-[#B9863B] focus-visible:ring-offset-2 focus-visible:ring-offset-[#F8F5EF] lg:h-[72px] lg:w-auto lg:min-w-[310px] lg:justify-between lg:gap-5 lg:px-7 lg:text-[17px]"
        >
          <span class="flex min-w-0 items-center gap-3 text-white lg:gap-5">
            <svg class="h-7 w-7 shrink-0 text-white lg:h-8 lg:w-8" viewBox="0 0 32 32" fill="none" aria-hidden="true">
              <path d="M5 27h22M7.5 24.5h17M9 12.5h14M6.5 10.5 16 5l9.5 5.5" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" />
              <path d="M10 13v9.5M15.5 13v9.5M21 13v9.5" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" />
            </svg>
            <span class="whitespace-nowrap text-white">Descubrir Quismondo</span>
          </span>
          <svg class="h-6 w-6 shrink-0 text-white" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M9 5l7 7-7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </a>
        <a
          href="#"
          class="inline-flex h-16 w-full items-center justify-center gap-3 rounded-[8px] border border-[#B9863B] bg-[#F8F5EF]/94 px-5 text-[17px] font-semibold text-[#9A6A24] shadow-[0_14px_28px_rgba(185,134,59,0.08)] outline-none backdrop-blur-sm transition hover:border-[#9A6A24] hover:text-[#071D3A] focus-visible:ring-2 focus-visible:ring-[#B9863B] focus-visible:ring-offset-2 focus-visible:ring-offset-[#F8F5EF] lg:h-[72px] lg:w-auto lg:min-w-[195px] lg:gap-5 lg:px-7 lg:text-[18px]"
        >
          <svg class="h-7 w-7 shrink-0 lg:h-8 lg:w-8" viewBox="0 0 32 32" fill="none" aria-hidden="true">
            <path d="M7 25V14l4-4 4 4v11M17 25V12l4-4 4 4v13M5 25h22" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" />
            <path d="M10 25v-5h2v5M20 25v-6h2v6M9 9V6M21 7V4M13 13h-2M23 12h-2" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
          Tradiciones
        </a>
    </div>

    <div class="mt-3 grid grid-cols-3 border-y border-[#071D3A]/10 bg-[#F8F5EF]/92 py-5 backdrop-blur-sm lg:mt-16 lg:max-w-[520px] lg:border-y-0 lg:bg-transparent lg:py-0 lg:backdrop-blur-0 xl:mt-20">
      {
        quickLinks.map((link, index) => (
          <a class={`flex min-h-[100px] flex-col items-center justify-center gap-3 px-2 text-center text-[#071D3A] outline-none transition-colors hover:text-[#B9863B] focus-visible:text-[#B9863B] lg:min-h-[112px] lg:gap-4 lg:px-3 ${index > 0 ? "border-l border-[#071D3A]/16" : ""}`} href="#">
            {link.icon === "heritage" && (
              <svg class="h-10 w-10 text-[#B9863B] lg:h-11 lg:w-11" viewBox="0 0 42 42" fill="none" aria-hidden="true">
                <path d="M7 35h28M10 35V20l11-9 11 9v15M16 35v-8a5 5 0 0 1 10 0v8" stroke="currentColor" stroke-width="1.55" stroke-linecap="round" stroke-linejoin="round" />
                <path d="M21 11V4M17.5 7.5h7M13 21h3M26 21h3M5 35V25l5-4M37 35V25l-5-4" stroke="currentColor" stroke-width="1.55" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            )}
            {link.icon === "calendar" && (
              <svg class="h-10 w-10 text-[#B9863B] lg:h-11 lg:w-11" viewBox="0 0 42 42" fill="none" aria-hidden="true">
                <rect x="8" y="10" width="26" height="25" rx="3.5" stroke="currentColor" stroke-width="1.65" />
                <path d="M14 6v8M28 6v8M8 18h26" stroke="currentColor" stroke-width="1.65" stroke-linecap="round" />
                <path d="M15 24h2M21 24h2M27 24h2M15 30h2M21 30h2M27 30h2" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" />
              </svg>
            )}
            {link.icon === "heart" && (
              <svg class="h-10 w-10 text-[#B9863B] lg:h-11 lg:w-11" viewBox="0 0 42 42" fill="none" aria-hidden="true">
                <path d="M21 34S8 26.4 8 15.9c0-4.5 3.2-7.4 7.1-7.4 2.4 0 4.6 1.3 5.9 3.3 1.3-2 3.5-3.3 5.9-3.3 3.9 0 7.1 2.9 7.1 7.4C34 26.4 21 34 21 34Z" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            )}
            <span class="max-w-[105px] text-[15px] font-medium leading-[1.35] lg:max-w-[115px] lg:text-[16px]">
              {link.label}
            </span>
          </a>
        ))
      }
    </div>
  </div>
</section>
