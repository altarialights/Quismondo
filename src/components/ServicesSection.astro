---
const services = [
  {
    title: "Solicitud genérica",
    description: "Presenta una solicitud o comunicación dirigida al Ayuntamiento.",
    href: "#",
    icon: "document",
  },
  {
    title: "Padrón municipal",
    description: "Consulta o gestiona trámites relacionados con el padrón.",
    href: "#",
    icon: "people",
  },
  {
    title: "Agua y contador",
    description: "Lectura, alta, baja o cambio de titular del contador de agua.",
    href: "#",
    icon: "water",
  },
  {
    title: "Licencia de obras",
    description: "Información y solicitud de licencias para obras municipales.",
    href: "#",
    icon: "works",
  },
  {
    title: "Ordenanzas y tasas",
    description: "Consulta precios públicos, tasas vigentes y normativa municipal.",
    href: "#",
    icon: "law",
  },
  {
    title: "Teléfonos de interés",
    description: "Encuentra contactos útiles y servicios de atención ciudadana.",
    href: "#",
    icon: "phone",
  },
];
---

<section class="bg-[#F8F5EF] py-16 sm:py-20 lg:py-24">
  <div class="mx-auto max-w-[1600px] px-5 sm:px-8 lg:px-10 xl:px-16">
    <div class="grid gap-8 border-t border-[#071D3A]/10 pt-12 lg:grid-cols-[minmax(0,0.95fr)_minmax(360px,0.75fr)] lg:items-end lg:gap-16">
      <div>
        <p class="text-[14px] font-bold uppercase tracking-[0.18em] text-[#B9863B]">
          Gestiones municipales
        </p>
        <h2 class="mt-3 font-serif text-[clamp(2.7rem,11vw,4.2rem)] font-medium leading-[0.95] tracking-normal text-[#071D3A] lg:text-[clamp(4rem,5vw,5.8rem)]">
          Trámites y servicios
        </h2>
        <div class="mt-6 h-px w-40 bg-[#B9863B]"></div>
      </div>

      <p class="max-w-[560px] text-[18px] font-medium leading-[1.55] text-[#071D3A]/78 lg:justify-self-end lg:text-[20px]">
        Accede de forma rápida a las gestiones y servicios más consultados del Ayuntamiento de Quismondo.
      </p>
    </div>

    <div class="mt-10 grid grid-cols-1 gap-5 sm:grid-cols-2 lg:mt-12 xl:grid-cols-3">
      {
        services.map((service) => (
          <a
            href={service.href}
            class="group flex min-h-[220px] flex-col rounded-[8px] border border-[#071D3A]/10 bg-[#FFFCF7] p-6 shadow-[0_14px_34px_rgba(7,29,58,0.06)] outline-none transition duration-200 hover:-translate-y-1 hover:border-[#B9863B]/70 hover:shadow-[0_20px_42px_rgba(7,29,58,0.1)] focus-visible:ring-2 focus-visible:ring-[#B9863B] focus-visible:ring-offset-2 focus-visible:ring-offset-[#F8F5EF] sm:p-7"
            aria-label={`Ver trámite: ${service.title}`}
          >
            <span class="flex h-14 w-14 items-center justify-center rounded-[8px] bg-[#B9863B]/12 text-[#B9863B] transition-colors group-hover:bg-[#B9863B] group-hover:text-white">
              {service.icon === "document" && (
                <svg class="h-8 w-8" viewBox="0 0 32 32" fill="none" aria-hidden="true">
                  <path d="M9 4.5h10l5 5V27H9V4.5Z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round" />
                  <path d="M19 4.5V10h5M13 15h7M13 19h7M13 23h4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              )}
              {service.icon === "people" && (
                <svg class="h-8 w-8" viewBox="0 0 32 32" fill="none" aria-hidden="true">
                  <path d="M5 27V15l11-8 11 8v12" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
                  <path d="M12 27v-5.5a4 4 0 0 1 8 0V27M10.5 16.5a2.5 2.5 0 1 0 0-5 2.5 2.5 0 0 0 0 5ZM21.5 16.5a2.5 2.5 0 1 0 0-5 2.5 2.5 0 0 0 0 5Z" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              )}
              {service.icon === "water" && (
                <svg class="h-8 w-8" viewBox="0 0 32 32" fill="none" aria-hidden="true">
                  <path d="M16 4.5s7 7.5 7 13.2a7 7 0 0 1-14 0C9 12 16 4.5 16 4.5Z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round" />
                  <path d="M13 20.5c1.2 1 3.8 1.4 6-.5M10 27h12" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
                </svg>
              )}
              {service.icon === "works" && (
                <svg class="h-8 w-8" viewBox="0 0 32 32" fill="none" aria-hidden="true">
                  <path d="M6 27h20M8 27V11l8-5 8 5v16M12 27v-8h8v8M12 14h2M18 14h2" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
                  <path d="M23.5 7.5 27 4M25 9l3-3" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
                </svg>
              )}
              {service.icon === "law" && (
                <svg class="h-8 w-8" viewBox="0 0 32 32" fill="none" aria-hidden="true">
                  <path d="M16 5v22M9 9h14M8 27h16M10 9l-5 8h10l-5-8ZM22 9l-5 8h10l-5-8Z" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              )}
              {service.icon === "phone" && (
                <svg class="h-8 w-8" viewBox="0 0 32 32" fill="none" aria-hidden="true">
                  <path d="M10.5 6.5 14 11l-2.4 2.4c1.5 3.1 3.9 5.5 7 7L21 18l4.5 3.5c.5.4.7 1 .5 1.6-.7 2-2.2 3.4-4.1 3.4C13.1 26.5 5.5 18.9 5.5 10.1c0-1.9 1.4-3.4 3.4-4.1.6-.2 1.2 0 1.6.5Z" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              )}
            </span>

            <h3 class="mt-6 text-[22px] font-bold leading-tight text-[#071D3A]">
              {service.title}
            </h3>
            <p class="mt-3 text-[16px] font-medium leading-[1.5] text-[#071D3A]/68">
              {service.description}
            </p>

            <span class="mt-auto flex items-center gap-2 pt-6 text-[15px] font-bold text-[#071D3A] transition-colors group-hover:text-[#B9863B]">
              Ver trámite
              <svg class="h-5 w-5 transition-transform group-hover:translate-x-1" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                <path d="M7 4.5 12.5 10 7 15.5" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </span>
          </a>
        ))
      }
    </div>

    <div class="mt-8 flex flex-col gap-5 rounded-[8px] border border-[#071D3A]/10 bg-white/55 p-6 shadow-[0_14px_32px_rgba(7,29,58,0.05)] sm:p-7 lg:mt-10 lg:flex-row lg:items-center lg:justify-between">
      <div>
        <p class="text-[14px] font-bold uppercase tracking-[0.16em] text-[#B9863B]">
          Acceso rápido
        </p>
        <p class="mt-2 text-[22px] font-bold leading-tight text-[#071D3A]">
          ¿No encuentras el trámite que necesitas?
        </p>
      </div>

      <a
        href="#"
        class="inline-flex h-14 items-center justify-center rounded-[8px] bg-[#071D3A] px-6 text-[16px] font-bold text-white shadow-[0_14px_28px_rgba(7,29,58,0.16)] outline-none transition hover:bg-[#0b2c57] focus-visible:ring-2 focus-visible:ring-[#B9863B] focus-visible:ring-offset-2 focus-visible:ring-offset-[#F8F5EF]"
      >
        Contactar con el Ayuntamiento
      </a>
    </div>
  </div>
</section>
